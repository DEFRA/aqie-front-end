{% extends 'layouts/page.njk' %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-l">{{ content.heading }}</h1>

      <p class="govuk-body">
        {{ content.bodyPrefix }}
        <a href="/search-location" class="govuk-link">{{ content.searchLinkText }}</a>{{ content.bodySuffix }}
      </p>

    </div>
  </div>
{% endblock %}
