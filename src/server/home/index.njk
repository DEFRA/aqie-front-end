{% extends 'layouts/page.njk' %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop govuk-!-margin-top-8 language-toggle">
      <h1 class="govuk-heading-xl">{{ heading }}</h1>
      <p class="govuk-body">{{ paragraphs.a }}</p>

      <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-6 govuk-!-margin-left-2">
        <li>{{ paragraphs.b }}</li>
        <li>{{ paragraphs.c }}</li>
      </ul>

      <p class="govuk-body">{{ paragraphs.d }}</p>

      <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-6 govuk-!-margin-left-2">
        <li>{{ paragraphs.e }}</li>
        <li>{{ paragraphs.f }}</li>
        <li>{{ paragraphs.g }}</li>
      </ul>

      {% include 'partials/inset-text.njk' %}

      {% include 'partials/start-button.njk' %}

      <h2 class="govuk-heading-m">{{ paragraphs.h }}</h2>

      <p class="govuk-body govuk-!-margin-bottom-1">{{ paragraphs.i }}</p>
      <p class="govuk-body govuk-!-margin-bottom-1">{{ paragraphs.j }}</p>
      <p class="govuk-body"><a href="https://www.gov.uk/call-charges" class="govuk-link">{{ paragraphs.k }}</a></p>
    </div>
  </div>
{% endblock %}