{
  "name": "aqie-front-end",
  "version": "0.15.0",
  "description": "CDP Frontend Template",
  "sideEffects": false,
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production webpack",
    "build:frontend": "cross-env NODE_ENV=production webpack",
    "dev": "run-p frontend:watch server:watch",
    "dev:debug": "run-p frontend:watch server:debug",
    "dev:perf-test": "cross-env NODE_ENV=perf-test SESSION_CACHE_ENGINE=memory nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "docker:dev": "npm run dev",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\"",
    "frontend:watch": "cross-env NODE_ENV=development webpack --watch",
    "git:pre-commit-hook": "npm run format:check && npm run lint && npm test",
    "postinstall": "npm run setup:husky",
    "lint": "run-s lint:js lint:scss",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "pretest": "npm run build:frontend",
    "test": "cross-env TZ=UTC NODE_OPTIONS=--max-old-space-size=4096 npx vitest run --coverage",
    "test:watch": "TZ=UTC vitest",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json --legacy-watch ./src",
    "prestart": "npm run build:frontend",
    "start": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "bot:test:monitor:start": "bash scripts/bot-redis-monitor.sh start",
    "bot:test:monitor:stop": "bash scripts/bot-redis-monitor.sh stop",
    "bot:test:monitor:status": "bash scripts/bot-redis-monitor.sh status",
    "bot:test:monitor:sample": "bash scripts/bot-redis-monitor.sh sample",
    "bot:test:monitor": "bash scripts/bot-redis-monitor.sh monitor",
    "bot:test:load": "npx autocannon -R ${BOT_RATE:-2} -d ${BOT_DURATION:-1800} ${BOT_URL:-http://localhost:3000/location/rawtenstall_rossendale}",
    "bot:test:run": "npm run bot:test:monitor:start && npm run bot:test:load; EXIT_CODE=$?; npm run bot:test:monitor:stop; exit $EXIT_CODE",
    "bot:test:server:redis": "cross-env SESSION_CACHE_ENGINE=redis npm run server:watch",
    "bot:test:load:redis": "cross-env SESSION_CACHE_ENGINE=redis npm run bot:test:load",
    "bot:test:run:redis": "cross-env SESSION_CACHE_ENGINE=redis npm run bot:test:run",
    "bot:test:run:redis:guards:global:on": "cross-env SESSION_CACHE_ENGINE=redis SESSION_GLOBAL_GUARD_ENABLED=true npm run bot:test:run",
    "bot:test:run:redis:guards:global:off": "cross-env SESSION_CACHE_ENGINE=redis SESSION_GLOBAL_GUARD_ENABLED=false npm run bot:test:run",
    "bot:test:run:redis:guards:global:ab": "bash scripts/run-redis-guard-ab.sh",
    "server:watch:redis": "cross-env PORT=3001 REDIS_HOST=127.0.0.1 REDIS_PORT=6379 REDIS_KEY_PREFIX=aqie-front-end: SESSION_CACHE_ENGINE=redis npm run server:watch",
    "redis:ports:clear": "bash scripts/clear-stale-redis-ports.sh",
    "redis:start": "brew services start redis",
    "redis:app:start": "run-s redis:ports:clear redis:start && cross-env SESSION_CACHE_ENGINE=redis PORT=3000 REDIS_HOST=127.0.0.1 REDIS_PORT=6379 REDIS_KEY_PREFIX=aqie-front-end: npm run server:watch",
    "redis:stop": "brew services stop redis",
    "redis:keys:count": "redis-cli --scan --pattern 'aqie-front-end:*' | wc -l",
    "redis:keys:delete": "redis-cli --scan --pattern 'aqie-front-end:*' | xargs -r redis-cli del",
    "redis:memory:total": "redis-cli info memory | grep used_memory_human",
    "redis:memory:frontend:bytes": "redis-cli --scan --pattern 'aqie-front-end:*' | xargs -I {} redis-cli memory usage {} | awk '{s+=$1} END {print s \" bytes\"}'",
    "redis:memory:frontend:mb": "redis-cli --scan --pattern 'aqie-front-end:*' | xargs -I {} redis-cli memory usage {} | awk '{s+=$1} END {printf \"%.2f MB\\n\", s/1024/1024}'",
    "redis:session:proof": "bash scripts/verify-redis-session.sh",
    "redis:session:proof:clean": "bash scripts/verify-redis-session-clean.sh",
    "perf:local:preflight": "cross-env PRECHECK_ONLY=1 bash scripts/local-perf-signoff.sh",
    "perf:local:signoff": "bash scripts/local-perf-signoff.sh",
    "perf:local:signoff:1h": "cross-env WARMUP_DURATION=600 DURATION=3600 bash scripts/local-perf-signoff.sh",
    "perf:local:signoff:strict": "cross-env THRESHOLD_MODE=strict bash scripts/local-perf-signoff.sh",
    "perf:local:signoff:local-realistic": "cross-env THRESHOLD_MODE=local-realistic bash scripts/local-perf-signoff.sh",
    "perf:local:signoff:cache-active": "cross-env PERF_PROFILE=cache-active-local bash scripts/local-perf-signoff.sh",
    "perf:local:signoff:cache-active:1h": "cross-env PERF_PROFILE=cache-active-local bash scripts/local-perf-signoff.sh",
    "perf:local:canary:1h": "cross-env PERF_PROFILE=cache-active-local THRESHOLD_MODE=local-realistic bash scripts/local-perf-canary.sh"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@babel/runtime": "7.27.0",
    "@defra/hapi-tracing": "^1.22.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/catbox-memory": "^6.0.2",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/cookie": "12.0.1",
    "@hapi/hapi": "21.4.0",
    "@hapi/inert": "7.1.0",
    "@hapi/vision": "7.0.3",
    "@hapi/yar": "11.0.3",
    "aws-embedded-metrics": "^4.2.0",
    "babel-plugin-module-resolver": "5.0.0",
    "caniuse-lite": "1.0.30001687",
    "convict": "6.2.4",
    "convict-format-with-validator": "6.2.0",
    "cssnano": "^5.1.0",
    "cssnano-preset-default": "^7.0.7",
    "date-fns": "4.1.0",
    "dotenv": "^16.4.5",
    "geolib": "3.3.4",
    "glob": "^11.0.3",
    "global-agent": "^3.0.0",
    "govuk-frontend": "^5.11.0",
    "hapi-pino": "12.1.0",
    "hapi-pulse": "^3.0.1",
    "https-proxy-agent": "7.0.4",
    "ioredis": "^5.6.1",
    "joi": "^18.0.2",
    "jsdom": "^26.1.0",
    "lodash": "4.17.21",
    "lru-cache": "^11.1.0",
    "moment": "2.30.1",
    "moment-timezone": "0.5.45",
    "mt-osgridref": "0.1.0",
    "node-fetch": "3.3.2",
    "nunjucks": "3.2.4",
    "object-sizeof": "2.6.5",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "proj4": "2.9.0",
    "rimraf": "^6.0.1",
    "undici": "^7.10.0",
    "util": "0.12.5"
  },
  "devDependencies": {
    "@babel/cli": "7.27.2",
    "@babel/core": "7.24.4",
    "@babel/node": "7.23.9",
    "@babel/preset-env": "7.24.4",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "cheerio": "1.1.0",
    "clean-webpack-plugin": "4.0.0",
    "copy-webpack-plugin": "13.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "7.1.0",
    "eslint": "9.29.0",
    "fast-xml-parser": "4.5.0",
    "husky": "9.1.7",
    "json-server": "0.17.4",
    "neostandard": "0.12.1",
    "nodemon": "3.1.10",
    "npm-run-all": "^4.1.5",
    "postcss-load-config": "^6.0.1",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.5.3",
    "resolve-url-loader": "5.0.0",
    "sass": "1.74.1",
    "sass-embedded": "^1.89.2",
    "sass-loader": "^16.0.5",
    "source-map-loader": "5.0.0",
    "style-loader": "4.0.0",
    "stylelint": "16.21.0",
    "stylelint-config-gds": "2.0.0",
    "terser-webpack-plugin": "5.3.14",
    "vitest": "^3.2.4",
    "vitest-fetch-mock": "0.4.5",
    "webpack": "5.99.9",
    "webpack-assets-manifest": "6.2.1",
    "webpack-cli": "^6.0.1",
    "xml2js": "0.6.2"
  }
}
