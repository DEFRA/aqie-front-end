# Required for OS Names API (UK geocoding)
OS_NAMES_API_KEY=

# Required: CDP X API Key (generate for test environment at https://portal.cdp-int.defra.cloud/user-profile)
# Note: Expires after 24 hours
CDP_X_API_KEY=

# Required: Session and cookie passwords (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_COOKIE_PASSWORD=
COOKIE_PASSWORD=

# Optional: DAQIE service authentication (ask AQ colleague if needed)
DAQIE_PASSWORD=

# Optional: Logging configuration (defaults are suitable for local development)
# LOG_ENABLED=true
# LOG_LEVEL=info
# LOG_FORMAT=pino-pretty

# Optional: Redis configuration (only needed if testing with Redis locally)
# In development, the app uses in-memory sessions by default
# To test with Redis locally, uncomment and configure:
# SESSION_CACHE_ENGINE=redis
# REDIS_HOST=127.0.0.1
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_KEY_PREFIX=aqie-front-end:
# REDIS_TLS=false

# Optional: Proxy settings if needed
# HTTP_PROXY=
# HTTPS_PROXY=

# Optional: Toggle new Ricardo measurements API (defaults to true in config)
# USE_NEW_RICARDO_MEASUREMENTS_ENABLED=true

# Notify Service Configuration
# NOTIFY_ENABLED=true
# NOTIFY_BASE_URL=https://aqie-notify-service.test.cdp-int.defra.cloud
# ALERT_BACKEND_BASE_URL=https://aqie-alert-back-end-service.test.cdp-int.defra.cloud

# Mock OTP Configuration (for local and test environments when GOV.UK Notify hits limits)
# Enable mock OTP fallback when real service fails or returns otp_generated_notification_failed
# NOTIFY_MOCK_OTP_ENABLED=true
# NOTIFY_MOCK_OTP_CODE=12345

# Mock Setup Alert Configuration (for local and test environments ONLY)
# WARNING: NEVER enable in production - this bypasses real alert subscription storage
# Enable mock alert fallback when backend service returns 502/503/504 (service unavailable)
# NOTIFY_MOCK_SETUP_ALERT_ENABLED=true

# Northern Ireland OS Places OAuth (only needed when testing NI flows without mocks)
# OS_PLACES_POSTCODE_NORTHERN_IRELAND_OAUTH_TOKEN_URL=https://login.microsoftonline.com
# OS_PLACES_POSTCODE_NORTHERN_IRELAND_TENANT_ID=
# OS_PLACES_POSTCODE_NORTHERN_IRELAND_CLIENT_ID=
# OS_PLACES_POSTCODE_NORTHERN_IRELAND_CLIENT_SECRET=
# OS_PLACES_POSTCODE_NORTHERN_IRELAND_REDIRECT_URI=
# OS_PLACES_POSTCODE_NORTHERN_IRELAND_SCOPE=api://<resource-app-id>/.default
