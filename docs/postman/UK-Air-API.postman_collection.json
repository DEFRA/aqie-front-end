{
  "info": {
    "name": "UK Air API",
    "description": "Postman collection for the UK Air API.\n\nEnvironments:\n- Staging: https://uk-air-api.staging.rcdo.co.uk\n- Prod: TBA\n\nAPI Docs: https://uk-air-api.staging.rcdo.co.uk/api/docs\n\nAuthentication: JWT via /api/login_check. Run the 'Login' request first — the token is automatically saved to the {{jwt_token}} variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://uk-air-api.staging.rcdo.co.uk",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "email",
      "value": "foobar@defra.gov.uk",
      "type": "string"
    },
    {
      "key": "password",
      "value": "foobar",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('jwt_token', json.token);",
                  "  console.log('JWT token saved to collection variable jwt_token');",
                  "} else {",
                  "  console.error('Login failed:', pm.response.text());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login_check",
              "host": ["{{base_url}}"],
              "path": ["api", "login_check"]
            },
            "description": "Authenticate and receive a JWT token.\n\nExpected responses:\n- HTTP 200: `{\"token\": \"Your-JWT\"}`\n- HTTP 401: `{\"code\": 401, \"message\": \"Invalid credentials.\"}`\n\nOn success the token is automatically saved to {{jwt_token}}."
          }
        }
      ]
    },
    {
      "name": "Site Metadata",
      "item": [
        {
          "name": "List all sites",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/site_meta_datas",
              "host": ["{{base_url}}"],
              "path": ["api", "site_meta_datas"]
            },
            "description": "Returns a list of all sites and related metadata."
          }
        },
        {
          "name": "List closed sites",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/site_meta_datas?with-closed=true",
              "host": ["{{base_url}}"],
              "path": ["api", "site_meta_datas"],
              "query": [
                {
                  "key": "with-closed",
                  "value": "true"
                }
              ]
            },
            "description": "Returns closed sites and related metadata.\n\nNOTE: Still under test — the closed site flag may not be working correctly."
          }
        },
        {
          "name": "List sites with pollutants metadata",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/site_meta_datas?with-pollutants=1&start-date=1982-02-02",
              "host": ["{{base_url}}"],
              "path": ["api", "site_meta_datas"],
              "query": [
                {
                  "key": "with-pollutants",
                  "value": "1"
                },
                {
                  "key": "start-date",
                  "value": "1982-02-02"
                }
              ]
            },
            "description": "Returns sites with related pollutants metadata from the given start date."
          }
        },
        {
          "name": "List sites with network details (AURN only)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/site_meta_datas?with-closed=1&networks[]=4&start-date=1982-02-02",
              "host": ["{{base_url}}"],
              "path": ["api", "site_meta_datas"],
              "query": [
                {
                  "key": "with-closed",
                  "value": "1"
                },
                {
                  "key": "networks[]",
                  "value": "4"
                },
                {
                  "key": "start-date",
                  "value": "1982-02-02"
                }
              ]
            },
            "description": "Returns sites with related network details. Currently returns AURN network only.\n\nNOTE: `networks[]=4` is specific to the AURN network. Changing this will have no effect."
          }
        },
        {
          "name": "List sites within a distance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/site_meta_datas?latitude=54.599650&longitude=-5.928833&distance=20",
              "host": ["{{base_url}}"],
              "path": ["api", "site_meta_datas"],
              "query": [
                {
                  "key": "latitude",
                  "value": "54.599650"
                },
                {
                  "key": "longitude",
                  "value": "-5.928833"
                },
                {
                  "key": "distance",
                  "value": "20"
                }
              ]
            },
            "description": "Returns sites within a given distance (miles) of a lat/long coordinate.\n\nNOTE: All three parameters `latitude`, `longitude` and `distance` must be provided. `distance` is in miles."
          }
        }
      ]
    },
