              "query": [
                {
                  "key": "pollutant-name",
                  "value": "O3"
                }
              ]
            },
            "description": "Returns measurements filtered by pollutant name.\n\nAvailable pollutants: CO, GE10, GR10, GR25, NO, NO2, NOXasNO2, NV10, NV25, O3, PM25, SO2, V10, V25, uGR10, uGR25"
          }
        },
        {
          "name": "List measurements by data type",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/pollutant_measurement_datas?data-type=12",
              "host": ["{{base_url}}"],
              "path": ["api", "pollutant_measurement_datas"],
              "query": [
                {
                  "key": "data-type",
                  "value": "12"
                }
              ]
            },
            "description": "Returns measurements filtered by data type.\n\nValues 12, 23 and 24 retrieve data from statistics. All other values use measurements."
          }
        },
        {
          "name": "List measurements between dates",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/pollutant_measurement_datas?start-date-time=2025-03-10 00:00:00&end-date-time=2025-03-12 23:59:00",
              "host": ["{{base_url}}"],
              "path": ["api", "pollutant_measurement_datas"],
              "query": [
                {
                  "key": "start-date-time",
                  "value": "2025-03-10 00:00:00"
                },
                {
                  "key": "end-date-time",
                  "value": "2025-03-12 23:59:00"
                }
              ]
            },
            "description": "Returns measurements between two date-times.\n\nNOTE: Both `start-date-time` and `end-date-time` are required. A large date range will negatively impact response time."
          }
        }
      ]
    },
